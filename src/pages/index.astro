                </div>
              </li>
              <li class="border-top with-icon">
                <div class="text">
                  <h2 class="h4 title"><span class="odometer second-font font-semi-bold" data-count="9">00</span>°</h2>
                  <p class="desc">System / identidad</p>
                </div>
              </li>
            </ul>
          </div>
          <div class="right-area">
            <div class="image-area">
              <div class="photo-placeholder" style="aspect-ratio: 802/700;">FOTO DEL TALLER — PENDIENTE</div>
            </div>
