<script>
  // Stop-motion logo animation — 8 frames, 0.1s each, looping (see CLAUDE.md).
  const FRAME_COUNT = 8;
  const FRAME_MS = 100;
  const img = document.getElementById("hero-logo-anim") as HTMLImageElement | null;

  if (img) {
    const frames = Array.from(
      { length: FRAME_COUNT },
      (_, i) => `/brand/logo-animation/frame-${i + 1}.png`,
    );
    frames.forEach((src) => {
      const preload = new Image();
      preload.src = src;
    });

    let i = 0;
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (!prefersReducedMotion) {
      setInterval(() => {
        i = (i + 1) % FRAME_COUNT;
        img.src = frames[i];
      }, FRAME_MS);
    }
  }
</script>

<script>
  // "Our Vision" pinned photo grows out from the exact center of the
  // viewport (main.js containerResize(), transformOrigin: center center) —
  // which sits right on top of the sticky headline (.floating-content,
  // z-index:-1, top:32.5%). Agenio's own CSS never fades that headline out,
  // so mid-transition the small growing placeholder and the small inline
  // "FOTO" teaser inside the headline are both on screen at once and read as
  // two competing photos (reported 2026-07-19). Cross-fading the headline
  // out over the same approach distance main.js already uses for the pin
  // (one full viewport height before "top top") makes it read as a single
  // photo taking over, instead of two placeholders overlapping.
  window.addEventListener("load", () => {
    const gsapGlobal = (window as any).gsap;
    const ScrollTriggerGlobal = (window as any).ScrollTrigger;
    if (!gsapGlobal || !ScrollTriggerGlobal) return;
    if (window.innerWidth <= 768) return; // matches main.js's own pin gate

    const floatingContent = document.querySelector(".wpr-project-area .floating-content");
    const pinWrap = document.querySelector(".wpr-video-pin");
    if (!floatingContent || !pinWrap) return;

    gsapGlobal.registerPlugin(ScrollTriggerGlobal);
    gsapGlobal.to(floatingContent, {
      opacity: 0,
      ease: "power1.in",
      scrollTrigger: {
        trigger: pinWrap,
        start: "top bottom",
        end: "top top",
        scrub: true,
      },
    });
  });
</script>
