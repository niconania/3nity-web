  <!-- wpr about area end -->

  <!-- wpr services area start -->
  <section id="services" class="wpr-services-area mb--16">
    <div class="container">
      <div class="section-inner bg-white border-1">
        <div class="section-top-area">
          <div class="section-title-area center-style">
            <p class="sub-title">MUST-HAVE 3D SERVICES</p>
            <h2 class="section-title second-font font-semi-bold text-normal wpr-text-anime-style-1">Diseñamos. Imprimimos.</h2>
          </div>
        </div>
        <div class="section-bottom-content square-dot">
          {SERVICES.map((s, i) => (
            <div class="service-wrapper wow fadeInRight" data-wow-delay={`${(i + 1) * 0.2}s`}>
              <div class="image-area">
                <div class="photo-placeholder" style="aspect-ratio: 4/3;">FOTO PENDIENTE</div>
              </div>
              <div class="content">
                <div class="top">
                  <p class="tag">{s.tag}</p>
                  <p class="desc">{s.desc}</p>
                </div>
                <div class="mid">
                  <h2>{s.num}</h2>
                </div>
                <div class="bottom">
                  <ul>
                    {s.items.map((item) => <li>{item}</li>)}
                  </ul>
                </div>
              </div>
            </div>
          ))}
          <span class="square-shape top-left"></span>
          <span class="square-shape top-right"></span>
        </div>
      </div>
    </div>
  </section>
  <!-- wpr services area end -->

  <!-- wpr project area start (Our Vision — manifesto + pinned scroll-grow
       project slider, literal architecture from Agenio's .wpr-video-pin,
       driven by main.js containerResize()/featureProjectHover(), see
       CLAUDE.md). Placeholder photos until real work photography exists. -->
  <section class="wpr-project-area mb--16">
    <div class="container">
      <div class="section-inner border-1">
        <div class="space"></div>
        <div class="floating-content">
          <div class="section-title-area center-style">
            <p class="sub-title bg-white">OUR VISION</p>
            <h2 class="section-title second-font font-semi-bold text-normal">
              Nace de un impulso <br>
              <span>de solucionar <span><span class="photo-placeholder inline-teaser">FOTO</span></span> sin</span> <br>
              tener que pedirlo
            </h2>
            <p class="desc">Buscamos crear cosas que las personas no quieren, sino que las necesitan.</p>
          </div>
        </div>
        <div class="wpr-video-pin">
          <div class="wpr-video-wrapper">
            <div class="swiper project-slider">
              <div class="swiper-wrapper">
                {VISION_PROJECTS.map((p) => (
                  <div class="swiper-slide">
                    <div class="slide feature-project">
                      <div class="image-area">
                        <div class="photo-placeholder video-img" style="width:100%;height:100%;">FOTO PENDIENTE</div>
                        <img src="/vendor/images/portfolio/shape-top-left.svg" alt="" class="shape top-left-shape" />
                        <img src="/vendor/images/portfolio/shape-top-right.svg" alt="" class="shape top-right-shape" />
                      </div>
                      <div class="slide-content">
                        <div class="product-intro">
                          <div class="top">
                            <h2 class="h3 title"><a href="#trabajos">{p.title}</a></h2>
                            <p class="desc">{p.desc}</p>
                          </div>
                          <div class="bottom">
                            <ul>
                              {p.stats.map((s) => (
                                <li>
                                  <h3 class="h5">{s.value}</h3>
                                  <p>{s.label}</p>
                                </li>
                              ))}
                            </ul>
                          </div>
                        </div>
                      </div>
                      <div class="hover_mouse">
                        <div class="box"></div>
                        <a href="#trabajos">
                          Ver trabajos
                          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M18 0V13.4751H16.5083V2.53591L1.0442 18L0 16.9061L15.4144 1.49171H4.47514V0H18Z" fill="#44FF02" /></svg>
                        </a>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
              <div class="swiper-navigation">
                <div class="swiper-btn slider-prev">
                  <svg width="17" height="30" viewBox="0 0 17 30" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M14.6094 0L0.859375 13.75L0 14.6484L0.859375 15.5469L14.6094 29.2969L16.4062 27.5L3.55469 14.6484L16.4062 1.79688L14.6094 0Z" fill="#F9FAFB"></path></svg>
                </div>
                <div class="swiper-btn slider-next">
                  <svg width="17" height="30" viewBox="0 0 17 30" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1.79688 0L0 1.79688L12.8516 14.6484L0 27.5L1.79688 29.2969L15.5469 15.5469L16.4062 14.6484L15.5469 13.75L1.79688 0Z" fill="#F9FAFB"></path></svg>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- wpr project area end -->

  <!-- wpr working process area start -->
  <section class="wpr-working-process mb--16">
    <div class="container">
      <div class="section-inner bg-white border-1">
        <div class="row">
          <div class="col-lg-6">
            <div class="working-process-left">
              <div class="section-title-area">
                <p class="sub-title">PRINT LIKE US IN 3 STEPS</p>
                <h2 class="section-title second-font font-semi-bold text-normal quote">De la idea <br> a la entrega</h2>
              </div>
              <div class="text-area">
                <p class="desc">Cada paso pensado para darte claridad y una pieza en tus manos.</p>
                <a href="#contact" class="wpr-btn btn-primary with-icon">Solicitar cotización</a>
              </div>
            </div>
          </div>
          <div class="col-lg-6">
            <div class="right-content-area">
              {PROCESS.map((p) => (
                <div class="working-process-wrapper">
                  <div class="image-area">
                    <video
                      src={`/videos/process/${p.video}.mp4`}
                      poster={`/videos/process/${p.video}-poster.jpg`}
                      autoplay
                      muted
                      loop
                      playsinline
                      preload="metadata"
                      aria-label={`Proceso: ${p.title}`}
                    />
                  </div>
                  <div class="content-area">
                    <div class="number">//{p.num}</div>
                    <div class="wrapper-content">
                      <h3 class="title second-font h6">{p.title}</h3>
                      <p class="desc">{p.desc}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- wpr working process area end -->

  <!-- wpr marquee area start -->
  <section class="wpr-marquee-area mb--16">
    <div class="container">
      <div class="section-inner overflow-hidden border-1">
        <div class="text-wrapper first-text">
          <div class="text-split scrollingtext-1">
            <h2 class="title">
              {Array.from({ length: 12 }).map(() => (
                <>PRECISIÓN <span><img src="/vendor/images/icon/black-right.svg" alt="" /></span> </>
              ))}
            </h2>
          </div>
        </div>
        <div class="text-wrapper">
          <div class="text-split scrollingtext-2">
            <h2 class="title">
              {Array.from({ length: 12 }).map(() => (
                <>MATERIA <span><img src="/vendor/images/icon/black-left.svg" alt="" /></span> </>
              ))}
            </h2>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- wpr marquee area end -->

  <!-- wpr team area start -->
  <section id="team" class="wpr-team-area mb--16">
    <div class="container">
      <div class="section-inner bg-white border-1">
        <div class="content-area">
          <div class="section-title-area center-style">
            <p class="sub-title">THE MINDS BEHIND 3NITY</p>
            <h2 class="section-title second-font font-semi-bold text-normal quote">Las mentes <br> detrás de 3NITY</h2>
          </div>
          <div class="section-bottom-inner">
            <div class="row g-24">
              {TEAM.map((m, i) => (
                <div class={`col-xl-4 col-md-6 wow ${i % 2 === 0 ? "fadeInDown" : "fadeInUp"}`} data-wow-delay={`${(i + 1) * 0.2}s`}>
                  <div class:list={["team-wrapper", { down: i % 2 !== 0 }]}>
                    <div class="image-area">
                      <div class="photo-placeholder" style="aspect-ratio: 1;">FOTO PENDIENTE</div>
                    </div>
                    <div class="author-area">
                      <h3 class="title h6">{m.name}</h3>
                      <p class="designation">{m.role}</p>
                      <div class="social">
                        <ul>
                          <li><a href={site.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram"><img src="/vendor/images/team/instagram.svg" alt="" /></a></li>
                          <li><a href={site.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"><img src="/vendor/images/team/linkedin.svg" alt="" /></a></li>
                        </ul>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- wpr team area end -->

  <!-- wpr testimonials area start (repurposed as featured-work carousel) -->
  <section id="trabajos" class="wpr-testimonials-area mb--16">
    <div class="container">
      <div class="section-inner border-1">
        <div class="section-title-area center-style">
          <p class="sub-title">FEATURED WORK</p>
          <h2 class="section-title second-font font-semi-bold text-normal">Trabajos destacados</h2>
        </div>
        <div class="swiper testimonials-image-slider">
          <div class="swiper-wrapper">
            {WORK_SLIDES.map((n) => (
              <div class="swiper-slide">
                <div class="image-area">
                  <div class="photo-placeholder" style="width:100%;height:100%;">PIEZA / {n}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="swiper testimonials-content-slider">
          <div class="swiper-wrapper">
            {WORK_SLIDES.map((n) => (
              <div class="swiper-slide">
                <div class="testimonials-content">
                  <div class="top">
                    <h2 class="title h5">Pieza / {n}</h2>
                    <p class="desc">Foto pendiente — próximamente en esta galería.</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="swiper-navigation">
          <div class="swiper-btn swiper-btn-prev">
            <svg width="17" height="30" viewBox="0 0 17 30" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M14.6094 0L0.859375 13.75L0 14.6484L0.859375 15.5469L14.6094 29.2969L16.4062 27.5L3.55469 14.6484L16.4062 1.79688L14.6094 0Z" fill="#F9FAFB"></path></svg>
          </div>
          <div class="swiper-btn swiper-btn-next">
            <svg width="17" height="30" viewBox="0 0 17 30" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1.79688 0L0 1.79688L12.8516 14.6484L0 27.5L1.79688 29.2969L15.5469 15.5469L16.4062 14.6484L15.5469 13.75L1.79688 0Z" fill="#F9FAFB"></path></svg>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- wpr testimonials area end -->

  <!-- wpr faq area start -->
  <section class="wpr-faq-area mb--16">
    <div class="container">
      <div class="section-inner bg-white border-1">
        <div class="section-content-area">
          <div class="section-title-area center-style">
            <p class="sub-title">FAQ</p>
            <h2 class="section-title second-font font-semi-bold text-normal">Preguntas frecuentes</h2>
          </div>
          <div class="accordion-one" id="accordionExample2">
            {FAQS.map((item, i) => (
              <div class="accordion-item">
                <h2 class="accordion-header" id={`heading${i}`}>
                  <button class:list={["accordion-button", { collapsed: i !== 0 }]} type="button" data-bs-toggle="collapse" data-bs-target={`#collapse${i}`} aria-expanded={i === 0} aria-controls={`collapse${i}`}>
                    {item.q}
                  </button>
                </h2>
                <div id={`collapse${i}`} class:list={["accordion-collapse", "collapse", { show: i === 0 }]} role="region" aria-labelledby={`heading${i}`} data-bs-parent="#accordionExample2">
