---
// Literal port of the Agenio template (see CLAUDE.md): real markup/classes/
// CSS from the licensed template, 3NITY content poured in. Single page,
// multi-page nav (about/service/work/blog) consolidated into anchors.
import Base from "../layouts/Base.astro";
import { site } from "../config";

const w3fKey = import.meta.env.PUBLIC_W3F_KEY ?? "";

const SERVICES = [
  {
    tag: "IMPRESIÓN 3D",
    desc: "Piezas únicas y series cortas. Geometría que el molde no puede hacer.",
    num: "01",
    items: ["Modelado a medida", "Múltiples materiales", "Acabado y postprocesado", "Series cortas"],
  },
  {
    tag: "MODELADO",
    desc: "Del boceto o la referencia al archivo listo para imprimir.",
    num: "02",
    items: ["Escaneo y referencia", "Diseño paramétrico", "Optimización para impresión", "Revisión contigo"],
  },
  {
    tag: "PROTOTIPOS",
    desc: "Prueba la forma y el ajuste antes de comprometer el material final.",
    num: "03",
    items: ["Iteración rápida", "Validación de ajuste", "Múltiples versiones", "De prueba a producción"],
  },
];

const PROCESS = [
  { num: "01", title: "Idea", desc: "Cuéntanos qué necesitas: una foto, un boceto, o solo la idea.", video: "idea" },
  { num: "02", title: "Cotización", desc: "Evaluamos el modelo y respondemos por correo con precio y tiempo de entrega.", video: "cotizacion" },
  { num: "03", title: "Entrega", desc: "Imprimimos, terminamos la pieza y coordinamos la entrega.", video: "entrega" },
];

const TEAM = [
  { name: "Sara A. Oliviero", role: "Chief Marketing Officer" },
  { name: "José S. Moreno", role: "Chief Financial Officer" },
  { name: "Nicola A. Nania", role: "Chief Technology Officer" },
];

const WORK_SLIDES = Array.from({ length: 6 }, (_, i) => String(i + 1).padStart(2, "0"));

const VISION_PROJECTS = [
  {
    title: "Pieza única",
    desc: "Una geometría irrepetible, resuelta en un solo intento. Sin molde, sin mínimos.",
    stats: [
      { value: "1/1", label: "Piezas irrepetibles" },
      { value: "STL · 3MF", label: "Formatos que aceptamos" },
      { value: "24–48h", label: "Tiempo de cotización" },
    ],
  },
  {
    title: "Prototipo",
    desc: "Prueba la forma y el ajuste antes de comprometer el material final.",
    stats: [
      { value: "0.1mm", label: "Resolución de capa" },
      { value: "6+", label: "Materiales disponibles" },
      { value: "Rápida", label: "Iteración" },
    ],
  },
  {
    title: "Serie corta",
    desc: "De la prueba a la producción, sin comprometer el acabado.",
    stats: [
      { value: "Sin mínimo", label: "Lote flexible" },
      { value: "Multi-material", label: "Impresión" },
      { value: "Nacional", label: "Envío" },
    ],
  },
];

const FAQS = [
  { q: "¿Qué archivos necesito enviar?", a: "STL o 3MF si ya tienes el modelo listo. Si no, cuéntanos la idea y te ayudamos a modelarla." },
  { q: "¿Cuánto tarda una cotización?", a: "Respondemos por correo en 24–48 horas con precio y tiempo estimado de entrega." },
  { q: "¿Hacen envíos fuera de la ciudad?", a: "Sí, coordinamos envío nacional. El costo se incluye en la cotización." },
  { q: "¿Puedo pedir una pieza única, no en serie?", a: "Sí — piezas únicas, series cortas y prototipos son nuestro fuerte." },
];
---

<Base>
  <!-- header area start -->
  <header class="header-style-one">
    <div class="container">
      <div class="header-style-one-wrapper">
        <div class="left-area square-dot">
          <div class="logo-area">
            <a href="#top" class="logo">3nity<sup>™</sup></a>
          </div>
          <span class="square-shape top-left"></span>
          <span class="square-shape bottom-left"></span>
          <span class="square-shape top-right"></span>
          <span class="square-shape bottom-right"></span>
        </div>
        <nav class="main-nav-area">
          <ul class="list-unstyled wpr-desktop-menu">
            <li class="menu-item active"><a class="main-element" href="#top">Inicio</a></li>
            <li class="menu-item"><a class="main-element" href="#services">Servicios</a></li>
            <li class="menu-item"><a class="main-element" href="#trabajos">Trabajos</a></li>
            <li class="menu-item"><a class="main-element" href="#team">Equipo</a></li>
            <li class="menu-item"><a class="main-element" href="#contact">Contacto</a></li>
          </ul>
        </nav>
        <div class="button-area-start square-dot">
          <a href="#contact" class="wpr-btn btn-primary">Solicitar cotización</a>
          <div class="menu-btn d-flex d-lg-none d-md-flex d-sm-flex" id="menu-btn">
            <span class="line one"></span>
            <span class="line two"></span>
          </div>
          <span class="square-shape top-left"></span>
          <span class="square-shape bottom-left"></span>
          <span class="square-shape top-right"></span>
          <span class="square-shape bottom-right"></span>
        </div>
        <div id="side-bar" class="side-bar">
          <div class="sidebar-inner">
            <div class="mobile-menu-main">
              <nav class="nav-main mainmenu-nav">
                <ul class="list-unstyled wpr-desktop-menu" id="mobile-menu">
                  <li class="menu-item"><a class="main-element" href="#top">Inicio</a></li>
                  <li class="menu-item"><a class="main-element" href="#services">Servicios</a></li>
                  <li class="menu-item"><a class="main-element" href="#trabajos">Trabajos</a></li>
                  <li class="menu-item"><a class="main-element" href="#team">Equipo</a></li>
                  <li class="menu-item"><a class="main-element" href="#contact">Contacto</a></li>
                </ul>
              </nav>
            </div>
            <div class="button-area">
              <a href="#contact" class="wpr-btn btn-primary">Contacto</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>
  <!-- header area end -->

  <!-- wpr banner area start -->
  <section class="wpr-banner-area" id="top">
    <div class="container">
      <div class="banner-content-area">
        <div class="top-shape wow fadeIn" data-wow-delay=".7s"></div>
        <h1 class="section-title">
          <span class="left-area square-dot wow fadeInLeft" data-wow-delay=".7s">
            <span class="text">IDEAMOS</span>
            <span class="square-shape top-right"></span>
            <span class="square-shape bottom-right"></span>
            <span class="arrow-track right">
              {Array.from({ length: 11 }).map(() => (
                <span class="arrow"><img src="/vendor/images/banner/icon/arrow-right.svg" alt="" /></span>
              ))}
            </span>
          </span>
          <span class="mid-icon wow scaleIn" data-wow-delay=".7s">
            <span class="frame">
              <span class="inner">
                <img id="hero-logo-anim" src="/brand/logo-animation/frame-1.png" width="150" alt="Isotipo 3NITY animado" />
              </span>
            </span>
          </span>
          <span class="right-area square-dot wow fadeInRight" data-wow-delay=".7s">
            <span class="arrow-track right">
              {Array.from({ length: 11 }).map(() => (
                <span class="arrow"><img src="/vendor/images/banner/icon/arrow-left.svg" alt="" /></span>
              ))}
            </span>
            <span class="text">IMPRIMIMOS</span>
            <span class="square-shape top-left"></span>
            <span class="square-shape bottom-left"></span>
          </span>
        </h1>
        <div class="text-area wow fadeInUp" data-wow-delay="1s">
          <p class="desc">Convertimos ideas en piezas físicas <br> con precisión técnica y acabado editorial.</p>
          <div class="button-area">
            <a href="#services" class="wpr-btn btn-white">Ver servicios</a>
            <a href="#contact" class="wpr-btn btn-primary with-icon">
              <div class="inner">
                <div class="icon">
                  {Array.from({ length: 6 }).map(() => (
                    <span><img src="/vendor/images/icon/button-arrow.svg" alt="" /></span>
                  ))}
                </div>
              </div>
              Solicitar cotización
            </a>
          </div>
        </div>
        <div class="bg-shape">
          <img src="/vendor/images/banner/shape/bg-shape.svg" alt="" />
        </div>
        <div class="banner-shape-area">
          <img src="/vendor/images/banner/shape/shape-01.svg" alt="" class="one wow fadeInLeft" data-wow-delay=".2s" />
          <img src="/vendor/images/banner/shape/shape-02.svg" alt="" class="two wow fadeInRight" data-wow-delay=".2s" />
        </div>
      </div>
    </div>
  </section>
  <!-- wpr banner area end -->

  <!-- wpr about area: oculta por ahora a pedido del usuario (2026-07-18),
       no aporta suficiente todavía debajo del hero. Marcado no visible en vez
       de borrado para poder reactivarlo. -->
  <!--
  <section id="about" class="wpr-about-area mb--16">
    <div class="container">
      <div class="section-inner bg-white border-1">
        <div class="section-top-area">
          <div class="section-title-area">
            <p class="sub-title">ESTUDIO</p>
            <h2 class="section-title second-font font-semi-bold text-normal quote">
              El buen diseño no es una imagen — es un objeto que puedes sostener
            </h2>
          </div>
        </div>
        <div class="about-bottom-content square-dot">
          <div class="left-area">
            <ul>
              <li class="border-top">
                <p class="top-description">NUESTROS NÚMEROS HABLAN POR SÍ SOLOS. <br> 3 FRIENDS &amp; 1 MACHINE.</p>
              </li>
              <li class="border-top with-icon">
                <div class="text">
                  <h2 class="h4 title"><span class="odometer second-font font-semi-bold" data-count="3">00</span></h2>
